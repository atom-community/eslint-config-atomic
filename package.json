{
  "name": "eslint-config-atomic",
  "version": "2.0.5",
  "description": "Eslint config used in atom-ide-community",
  "repository": "https://github.com/atom-ide-community/eslint-config-atomic",
  "license": "MIT",
  "author": "Amin Yahyaabadi",
  "type": "commonjs",
  "main": "index.js",
  "files": [
    "src",
    "dist",
    "*.cjs",
    "*.js"
  ],
  "scripts": {
    "build": "tsc --pretty",
    "bump": "ncu -u -x coffeescript,execa,read-pkg-up,make-synchronous && pnpm update && pnpm dedupe",
    "clean": "shx rm -rf ./spec/fixtures/ ./dist ./*.tsbuildinfo",
    "dev": "tsc --pretty --watch",
    "format": "prettier --cache -l --write .",
    "lint": "pnpm run build && eslint ./ --fix",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "tsx --tsconfig ./spec/tsconfig.json ./spec/test.mts",
    "test.format": "prettier --cache . --check",
    "test.lint": "cross-env NODE_OPTIONS=--enable-source-maps eslint ."
  },
  "prettier": "prettier-config-atomic",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-syntax-flow": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.59.1",
    "anymatch": "^3.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-only-warn": "npm:@aminya/eslint-plugin-only-warn@^1.2.2",
    "eslint-plugin-optimize-regex": "github:aminya/eslint-plugin-optimize-regex#16f9506ed2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-yaml": "^1.1.3",
    "globals": "^16.5.0",
    "globify-gitignore": "^1.0.3",
    "make-synchronous": "^0.1.1",
    "prettier": "3.5.3",
    "read-pkg-up": "^7.0.1",
    "semver": "^7.7.4",
    "subsume": "^3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  },
  "devDependencies": {
    "@eslint/core": "^1.2.1",
    "@types/babel__core": "^7.20.5",
    "@types/coffeescript": "^2.5.7",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint__js": "^8.42.3",
    "@types/execa": "^2.0.2",
    "@types/fs-extra": "~11.0.4",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.19.17",
    "@types/read-pkg-up": "^6.0.0",
    "@types/semver": "^7.7.1",
    "@types/shelljs": "^0.8.17",
    "cross-env": "^10.1.0",
    "eslint-config-atomic": "link:",
    "execa": "^5.1.1",
    "fs-extra": "^11.3.4",
    "gitly": "^3.2.4",
    "npm-check-updates": "17.1.16",
    "prettier-config-atomic": "^4.0.0",
    "shelljs": "^0.9.2",
    "shx": "^0.4.0",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "eslint": "^9"
  },
  "optionalDependencies": {
    "coffeescript": "^1.12.7",
    "eslint-plugin-coffee": "^0.1.15",
    "eslint-plugin-react-hooks": "^5.2.0"
  },
  "keywords": [
    "eslint",
    "config",
    "atomic",
    "plugin",
    "lint",
    "prettier"
  ],
  "react": "react.js",
  "strict": "strict.js",
  "strict-react": "strict-react.js"
}
