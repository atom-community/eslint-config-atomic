{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Eslint",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/node_modules/eslint/bin/eslint.js",
            "args": [
                "${workspaceFolder}/spec/fixtures/atom-community/atom-ide-hyperclick"
            ],
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ],
            "sourceMaps": true,
            "env": {
                "NODE_OPTIONS": "--enable-source-maps"
            }
        }
    ]
}
